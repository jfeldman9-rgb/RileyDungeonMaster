config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Riley vs Kenzie - Dungeon Master"
run/main_scene="res://scenes/open_world_prototype.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/global_state.gd"

[display]

